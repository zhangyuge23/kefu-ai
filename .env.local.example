# ============================================
# 可孚AI数字人平台 - 环境变量示例
# ============================================
# 使用方式：
# 1. 复制此文件为 .env.local
# 2. 填写你的实际配置
# ============================================

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===== ZPAY 支付 =====
ZPAY_PID=your-merchant-id
ZPAY_KEY=your-merchant-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== AI Proxy =====
AI_PROXY_URL=http://your-server-ip:8317
AI_API_KEY=free

# ===== n8n =====
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-domain/webhook/video-generate
NEXT_PUBLIC_N8N_WEBHOOK_SECRET=your-webhook-secret

# ===== 无音科技 API（数字人视频） =====
NEXT_PUBLIC_WUYIN_API_KEY=your-wuyin-api-key
WUYIN_API_URL=https://api.wuyinkeji.com

# ===== 阿里云百炼（语音服务） =====
DASHSCOPE_API_KEY=sk-your-api-key
